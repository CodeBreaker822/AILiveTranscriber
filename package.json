{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:vad": "node scripts/run-php.mjs artisan app:build-vad-cli",
        "build:tauri": "node scripts/prepare-desktop.mjs",
        "build:tauri:empty": "node scripts/prepare-desktop.mjs empty",
        "dev": "vite",
        "artisan": "node scripts/run-php.mjs artisan",
        "composer": "node scripts/run-php.mjs composer.phar",
        "dev:local": "node scripts/dev-local.mjs",
        "setup:local": "node scripts/run-php.mjs composer.phar run setup",
        "runtime:composer": "node scripts/run-php.mjs composer.phar --version",
        "runtime:node": "node --version",
        "runtime:npm": "npm --version",
        "runtime:php": "node scripts/run-php.mjs --version",
        "diagnostic:real": "node scripts/real-workflow-diagnostic.mjs",
        "test:updater": "node scripts/test-updater.mjs",
        "tauri:update-test": "node scripts/test-updater.mjs",
        "tauri:update": "powershell -ExecutionPolicy Bypass -File scripts/push-tauri-update.ps1",
        "clean:tauri": "node scripts/clean-tauri-cache.mjs",
        "tauri:dev": "tauri dev",
        "tauri": "tauri",
        "tauri:build": "node scripts/build-desktop.mjs",
        "tauri:build:empty": "node scripts/build-desktop.mjs empty",
        "tauri:package": "node scripts/build-desktop.mjs",
        "build:package": "node scripts/build-desktop.mjs",
        "tauri:package:empty": "node scripts/build-desktop.mjs empty",
        "update:package": "node scripts/build-desktop.mjs"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@tauri-apps/cli": "^2.11.2",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
