{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:tauri": ".\\php\\php.exe artisan app:prepare-tauri-build && vite build",
        "build:tauri:empty": ".\\php\\php.exe artisan app:prepare-tauri-empty-build && vite build",
        "dev": "vite",
        "artisan": ".\\php\\php.exe artisan",
        "composer": ".\\php\\php.exe .\\composer.phar",
        "dev:local": ".\\php\\php.exe .\\composer.phar run dev",
        "setup:local": ".\\php\\php.exe .\\composer.phar run setup",
        "runtime:composer": ".\\php\\php.exe .\\composer.phar --version",
        "runtime:node": ".\\node\\node.exe -v",
        "runtime:npm": ".\\node\\npm.cmd -v",
        "runtime:php": ".\\php\\php.exe -v",
        "tauri:dev": "tauri dev",
        "tauri:build": "tauri build",
        "tauri:build:empty": "tauri build --config tauri.empty.conf.json"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@tauri-apps/cli": "^2.11.2",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
