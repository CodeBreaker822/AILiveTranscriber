{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:vad": "node scripts/run-php.mjs artisan app:build-vad-cli",
        "build:tauri": "node scripts/prepare-desktop.mjs",
        "build:tauri:empty": "node scripts/prepare-desktop.mjs empty",
        "dev": "node scripts/dev-local.mjs",
        "artisan": "node scripts/run-php.mjs artisan",
        "composer": "node scripts/run-php.mjs composer.phar",
        "dev:local": "node scripts/dev-local.mjs",
        "setup:local": "node scripts/run-php.mjs composer.phar run setup",
        "runtime:composer": "node scripts/run-php.mjs composer.phar --version",
        "runtime:node": "node --version",
        "runtime:npm": "npm --version",
        "runtime:php": "node scripts/run-php.mjs --version",
        "tauri:dev": "tauri dev",
        "release:windows": "node scripts/build-desktop.mjs windows",
        "release:windows:empty": "node scripts/build-desktop.mjs windows empty",
        "tauri:build": "node scripts/build-desktop.mjs",
        "tauri:build:windows": "node scripts/build-desktop.mjs windows",
        "tauri:build:linux": "node scripts/build-desktop.mjs linux",
        "tauri:build:empty": "node scripts/build-desktop.mjs current empty",
        "tauri:build:empty:windows": "node scripts/build-desktop.mjs windows empty",
        "tauri:build:empty:linux": "node scripts/build-desktop.mjs linux empty",
        "update:package": "node scripts/create-update-package.mjs"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@tauri-apps/cli": "^2.11.2",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
