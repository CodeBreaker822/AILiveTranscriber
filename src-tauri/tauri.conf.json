{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AITranscriber APP",
  "version": "3.0.0-stablesaver",
  "identifier": "com.jerven.laravel-ai-transcriber",
  "build": {
    "beforeDevCommand": "node scripts/dev-local.mjs",
    "beforeBuildCommand": "node scripts/prepare-desktop.mjs",
    "devUrl": "http://127.0.0.1:8010/up"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AITranscriber",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "visible": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
